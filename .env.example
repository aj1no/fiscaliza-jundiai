# Configuracoes do banco de dados
POSTGRES_USER=fiscaliza
POSTGRES_PASSWORD=fiscaliza
POSTGRES_DB=fiscaliza_jundiai
DATABASE_URL=postgresql://fiscaliza:fiscaliza@db:5432/fiscaliza_jundiai

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Coleta do Portal da Transparencia
# Ajuste o ano conforme o exercicio desejado.
PORTAL_TRANSPARENCIA_ANO=2026
# Janela por ano para backfill controlado (ex.: 2025 ate 2026).
PORTAL_TRANSPARENCIA_ANO_INICIAL=2025
PORTAL_TRANSPARENCIA_ANO_FINAL=2026
# Teto de seguranca para evitar janelas grandes sem querer.
PORTAL_TRANSPARENCIA_MAX_ANOS_COLETA=10

# Meses da remuneracao:
# - Se nao definir, anos passados coletam 1..12 e o ano atual coleta 1..mes de referencia.
# - Se definir qualquer uma dessas variaveis, o intervalo fixo vale para todos os anos.
# PORTAL_TRANSPARENCIA_MES=4
# PORTAL_TRANSPARENCIA_MES_INICIAL=1
# PORTAL_TRANSPARENCIA_MES_FINAL=12

# Licitacoes
PORTAL_TRANSPARENCIA_LIMIT=100
PORTAL_TRANSPARENCIA_PAGE_SIZE=100

# Dados financeiros usados pelo painel publico
PORTAL_TRANSPARENCIA_DESPESAS_SECRETARIA_LIMIT=150
PORTAL_TRANSPARENCIA_CONTRATOS_LIMIT=150
PORTAL_TRANSPARENCIA_RECEITAS_LIMIT=150

# RAG / busca vetorial
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=250
RAG_VECTOR_DIMENSIONS=384

# Qdrant Cloud/local opcional.
# Quando vazio, o sistema usa o fallback local no PostgreSQL.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=fiscaliza_jundiai_chunks
QDRANT_TIMEOUT=20
