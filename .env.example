# Configurações do Banco de Dados
POSTGRES_USER=fiscaliza
POSTGRES_PASSWORD=fiscaliza
POSTGRES_DB=fiscaliza_jundiai
DATABASE_URL=postgresql://fiscaliza:fiscaliza@db:5432/fiscaliza_jundiai

# Configurações do Redis
REDIS_URL=redis://redis:6379/0

# Configurações do Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Configurações de Coleta
PORTAL_TRANSPARENCIA_ANO=2024
PORTAL_TRANSPARENCIA_LIMIT=100
PORTAL_TRANSPARENCIA_PAGE_SIZE=100
